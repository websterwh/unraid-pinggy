        <span class="pinggy-note">Send keep-alive packets for a stable connection, every</span>
        <input type="text" name="keepalive" value="<?= htmlspecialchars($cfg['KEEPALIVE']) ?>" style="width:60px; display:inline-block;"> sec
      </td>
    </tr>
    <tr>
      <td>Force New Tunnel</td>
      <td><input type="checkbox" name="use_force" <?= $cfg['USE_FORCE']==='1' ? 'checked' : '' ?>>
        <span class="pinggy-note">Close any existing tunnel on this token and start fresh (recommended - a Pro token only allows one active session)</span></td>
    </tr>
    <tr>
      <td>Start automatically on array start</td>
      <td><input type="checkbox" name="autostart" <?= $cfg['AUTOSTART']==='1' ? 'checked' : '' ?>></td>

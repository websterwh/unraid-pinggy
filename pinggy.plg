        <input type="text" name="pinggy_host" value="" placeholder="leave blank to use Region above">
        <div class="pinggy-note">Currently resolved to: <b><?= htmlspecialchars($cfg['PINGGY_HOST']) ?></b>. Fill this in to bypass the Region setting entirely.</div>
      </td>

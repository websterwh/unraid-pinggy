  <input type="hidden" name="csrf_token" value="<?= $csrf ?>">
  <input type="submit" class="btn" value="Restart Tunnel">
</form>

<h3>Connection</h3>
<form method="post" action="/plugins/pinggy/action.php?do=save_settings" target="progressFrame">
  <input type="hidden" name="csrf_token" value="<?= $csrf ?>">
  <table class="pinggy-table pinggy-toggle-row">
    <tr>
      <td>Pinggy Pro token</td>
      <td><input type="text" name="token" value="<?= htmlspecialchars($cfg['TOKEN']) ?>" placeholder="e.g. xGBTh6cy58q"></td>
    </tr>
    <tr>
      <td>Region</td>
      <td>
        <select name="region">
          <?php foreach ($regionLabels as $key => $label): ?>
            <option value="<?= $key ?>" <?= $cfg['REGION']===$key ? 'selected' : '' ?>><?= $label ?></option>
          <?php endforeach; ?>
        </select>
        <div class="pinggy-note">Picks the Pinggy edge server. South America / Australia have no published dedicated hostname yet, so they fall back to Auto.</div>
      </td>
    </tr>
